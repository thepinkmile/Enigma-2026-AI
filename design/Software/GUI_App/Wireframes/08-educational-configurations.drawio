        <mxCell id="cf-tbl-row-5-c0" value="UKW-B thin" style="text;strokeColor=none;fillColor=none;fontSize=10;fontColor=#FFB74D;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="92" y="928" width="152" height="28" as="geometry"/></mxCell>
        <mxCell id="cf-tbl-row-5-c1" value="ENKQAUYWJICP…" style="text;strokeColor=none;fillColor=none;fontSize=9;fontStyle=1;fontColor=#80CBC4;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="252" y="928" width="342" height="28" as="geometry"/></mxCell>
