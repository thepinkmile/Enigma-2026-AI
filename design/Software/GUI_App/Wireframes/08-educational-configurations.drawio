        <mxCell id="cf-img-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#001A12;strokeColor=#1A4030;" vertex="1" parent="1"><mxGeometry x="88" y="186" width="1228" height="210" as="geometry"/></mxCell>
        <mxCell id="cf-img-overlay" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#002B22;strokeColor=none;opacity=40;" vertex="1" parent="1"><mxGeometry x="88" y="186" width="1228" height="210" as="geometry"/></mxCell>
        <mxCell id="cf-img-inner" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1A2A1A;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="128" y="196" width="1148" height="190" as="geometry"/></mxCell>
        <mxCell id="cf-img-label" value="[ PERIOD PHOTOGRAPH / ARCHIVE ILLUSTRATION ]" style="text;strokeColor=none;fillColor=none;fontSize=13;fontColor=#3D6B60;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="88" y="186" width="1228" height="210" as="geometry"/></mxCell>
        <mxCell id="cf-img-caption" value="Enigma M4 four-rotor naval machine used by Kriegsmarine U-boats from February 1942" style="text;strokeColor=none;fillColor=none;fontSize=10;fontStyle=2;fontColor=#2A5040;align=center;verticalAlign=bottom;" vertex="1" parent="1"><mxGeometry x="88" y="186" width="1228" height="206" as="geometry"/></mxCell>
        <mxCell id="cf-div1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1A4030;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="88" y="404" width="1248" height="1" as="geometry"/></mxCell>
        <mxCell id="cf-desc-hdr" value="DESCRIPTION" style="text;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#80CBC4;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="88" y="410" width="200" height="24" as="geometry"/></mxCell>
        <mxCell id="cf-desc-p1" value="The Enigma M4 was a four-rotor variant of the Enigma cipher machine, introduced by the Kriegsmarine on 1 February 1942 for U-boat communications. Unlike the standard three-rotor Enigma I used by the Wehrmacht and Luftwaffe, the M4 added a fourth rotor position — occupied by a thin Greek rotor (Beta or Gamma) paired with a correspondingly thin reflector (UKW-B thin or UKW-C thin). This additional rotor dramatically increased the key space, temporarily blinding Allied codebreakers at Bletchley Park for nearly ten months." style="text;strokeColor=none;fillColor=none;fontSize=11;fontColor=#AAAAAA;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="88" y="438" width="1228" height="90" as="geometry"/></mxCell>
        <mxCell id="cf-desc-p2" value="The introduction of the M4 marked a significant setback for Operation Ultra. Analysts at Bletchley Park, including Alan Turing’s Hut 8 team, had to develop a new attack methodology to accommodate the extra rotor. The break eventually came in December 1942 when a captured short weather signal provided the first confirmed M4 cribs. The M4 remained in service until the end of the war and is considered among the most secure field cipher machines deployed by any combatant nation during the Second World War." style="text;strokeColor=none;fillColor=none;fontSize=11;fontColor=#AAAAAA;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="88" y="534" width="1228" height="84" as="geometry"/></mxCell>
        <mxCell id="cf-div2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1A4030;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="88" y="626" width="1248" height="1" as="geometry"/></mxCell>
        <mxCell id="cf-ref-hdr" value="REFERENCES &amp; FURTHER READING" style="text;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#80CBC4;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="88" y="632" width="400" height="24" as="geometry"/></mxCell>
        <mxCell id="cf-ref-0" value="•  Cryptomuseum.com — Enigma M4 (Naval Four-Rotor Machine)" style="text;strokeColor=none;fillColor=none;fontSize=11;fontColor=#5599DD;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="88" y="660" width="1228" height="20" as="geometry"/></mxCell>
        <mxCell id="cf-ref-1" value="•  Wikipedia: Enigma machine — Naval Enigma variants and the M4" style="text;strokeColor=none;fillColor=none;fontSize=11;fontColor=#5599DD;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="88" y="682" width="1228" height="20" as="geometry"/></mxCell>
        <mxCell id="cf-ref-2" value="•  National Security Agency / Bletchley Park Trust: Cryptographic Heritage Archive" style="text;strokeColor=none;fillColor=none;fontSize=11;fontColor=#5599DD;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="88" y="704" width="1228" height="20" as="geometry"/></mxCell>
        <mxCell id="cf-div3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1A4030;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="88" y="726" width="1248" height="1" as="geometry"/></mxCell>
        <mxCell id="cf-rotor-hdr" value="ROTOR SPECIFICATIONS" style="text;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#80CBC4;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="88" y="732" width="400" height="24" as="geometry"/></mxCell>
