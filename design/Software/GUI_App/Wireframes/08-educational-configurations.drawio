        <mxCell id="cf-tbl-hdr-0" value="ROTOR / REFLECTOR" style="text;strokeColor=none;fillColor=none;fontSize=10;fontStyle=1;fontColor=#80CBC4;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="92" y="760" width="152" height="28" as="geometry"/></mxCell>
