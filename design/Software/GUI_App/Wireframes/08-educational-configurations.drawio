        <mxCell id="cf-tbl-row-5-c3" value="Thin reflector. Paired with Beta for standard key traffic." style="text;strokeColor=none;fillColor=none;fontSize=10;fontColor=#777777;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="712" y="928" width="600" height="28" as="geometry"/></mxCell>
        <mxCell id="cf-tbl-row-6-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#001A12;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="88" y="956" width="1228" height="28" as="geometry"/></mxCell>
        <mxCell id="cf-tbl-row-6-c0" value="UKW-C thin" style="text;strokeColor=none;fillColor=none;fontSize=10;fontColor=#FFB74D;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="92" y="956" width="152" height="28" as="geometry"/></mxCell>
        <mxCell id="cf-tbl-row-6-c1" value="RDOBJNTKVEHM…" style="text;strokeColor=none;fillColor=none;fontSize=9;fontStyle=1;fontColor=#80CBC4;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="252" y="956" width="342" height="28" as="geometry"/></mxCell>
        <mxCell id="cf-tbl-row-6-c2" value="—" style="text;strokeColor=none;fillColor=none;fontSize=10;fontColor=#AAAAAA;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="602" y="956" width="102" height="28" as="geometry"/></mxCell>
        <mxCell id="cf-tbl-row-6-c3" value="Thin reflector. Paired with Gamma for special traffic." style="text;strokeColor=none;fillColor=none;fontSize=10;fontColor=#777777;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="712" y="956" width="600" height="28" as="geometry"/></mxCell>
        <mxCell id="cf-div4" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1A4030;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="88" y="988" width="1248" height="1" as="geometry"/></mxCell>
        <mxCell id="cf-tech-hdr" value="TECHNICAL DIAGRAMS &amp; MATHEMATICAL NOTATION" style="text;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#80CBC4;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="88" y="994" width="600" height="24" as="geometry"/></mxCell>
        <mxCell id="cf-diag-l-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1A4030;" vertex="1" parent="1"><mxGeometry x="88" y="1022" width="596" height="180" as="geometry"/></mxCell>
        <mxCell id="cf-diag-l-title" value="Encryption Permutation Chain" style="text;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#1A2A1A;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="96" y="1026" width="580" height="22" as="geometry"/></mxCell>
        <mxCell id="cf-diag-l-divider" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#CCCCCC;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="88" y="1050" width="596" height="1" as="geometry"/></mxCell>
        <mxCell id="cf-diag-l-formula" value="E(x) = P · Rβ · RI · RII · RIII · Λ · R⁻III · R⁻II · R⁻I · R⁻β · P⁻" style="text;strokeColor=none;fillColor=none;fontSize=14;fontStyle=2;fontColor=#1A1A1A;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="96" y="1054" width="580" height="36" as="geometry"/></mxCell>
        <mxCell id="cf-diag-l-legend" value="Where:&#xa;  P = plugboard permutation&#xa;  Rβ = Greek rotor (Beta or Gamma)&#xa;  RI, RII, RIII = selected standard rotors&#xa;  Λ = thin reflector (UKW-B thin or UKW-C thin)&#xa;  R⁻ = inverse of rotor permutation (return path)" style="text;strokeColor=none;fillColor=none;fontSize=10;fontColor=#333333;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="96" y="1094" width="580" height="100" as="geometry"/></mxCell>
        <mxCell id="cf-diag-r-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1A4030;" vertex="1" parent="1"><mxGeometry x="692" y="1022" width="596" height="180" as="geometry"/></mxCell>
        <mxCell id="cf-diag-r-title" value="Plugboard Substitution (Stecker) Notation" style="text;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#1A2A1A;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="700" y="1026" width="580" height="22" as="geometry"/></mxCell>
        <mxCell id="cf-diag-r-divider" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#CCCCCC;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="692" y="1050" width="596" height="1" as="geometry"/></mxCell>
        <mxCell id="cf-diag-r-formula" value="σ = (A D)(B N)(C K)(F I)(G J)(H M)(L U)(O V)(P X)(R Z)" style="text;strokeColor=none;fillColor=none;fontSize=14;fontStyle=2;fontColor=#1A1A1A;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="700" y="1054" width="580" height="36" as="geometry"/></mxCell>
        <mxCell id="cf-diag-r-legend" value="Example 10-pair plugboard configuration.&#xa;Each pair (x y) swaps letters x ↔ y before and&#xa;after rotor passage, adding 150 trillion additional&#xa;key combinations to the total cipher key space.&#xa;Notation: σ denotes the overall substitution permutation." style="text;strokeColor=none;fillColor=none;fontSize=10;fontColor=#333333;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="700" y="1094" width="580" height="100" as="geometry"/></mxCell>
        <mxCell id="cf-fade-0" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#002B22;strokeColor=none;opacity=15;" vertex="1" parent="1"><mxGeometry x="88" y="950" width="1248" height="20" as="geometry"/></mxCell>
        <mxCell id="cf-fade-1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#002B22;strokeColor=none;opacity=35;" vertex="1" parent="1"><mxGeometry x="88" y="970" width="1248" height="20" as="geometry"/></mxCell>
        <mxCell id="cf-fade-2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#002B22;strokeColor=none;opacity=60;" vertex="1" parent="1"><mxGeometry x="88" y="990" width="1248" height="22" as="geometry"/></mxCell>
        <mxCell id="cf-fade-3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#002B22;strokeColor=none;opacity=88;" vertex="1" parent="1"><mxGeometry x="88" y="1012" width="1248" height="28" as="geometry"/></mxCell>
