        <mxCell id="hw-tbl-row-6-c0" value="UKW-B" style="text;strokeColor=none;fillColor=none;fontSize=10;fontColor=#FFB74D;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="260" y="956" width="152" height="28" as="geometry"/></mxCell>
        <mxCell id="hw-tbl-row-6-c1" value="YRUHQSLDPXNGOK…" style="text;strokeColor=none;fillColor=none;fontSize=9;fontStyle=1;fontColor=#80CBC4;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="420" y="956" width="492" height="28" as="geometry"/></mxCell>
        <mxCell id="hw-tbl-row-6-c2" value="—" style="text;strokeColor=none;fillColor=none;fontSize=10;fontColor=#AAAAAA;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="920" y="956" width="122" height="28" as="geometry"/></mxCell>
        <mxCell id="hw-tbl-row-6-c3" value="Standard reflector from 1937. Most common in captured machines." style="text;strokeColor=none;fillColor=none;fontSize=10;fontColor=#777777;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1050" y="956" width="850" height="28" as="geometry"/></mxCell>
        <mxCell id="hw-div4" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1A4030;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="256" y="988" width="1656" height="1" as="geometry"/></mxCell>
        <mxCell id="hw-tech-hdr" value="TECHNICAL DIAGRAMS &amp; MATHEMATICAL NOTATION" style="text;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#80CBC4;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="256" y="994" width="700" height="24" as="geometry"/></mxCell>
        <mxCell id="hw-diag-l-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1A4030;" vertex="1" parent="1"><mxGeometry x="256" y="1022" width="820" height="180" as="geometry"/></mxCell>
        <mxCell id="hw-diag-l-title" value="Encryption Permutation Chain (Enigma I)" style="text;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#1A2A1A;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="264" y="1026" width="804" height="22" as="geometry"/></mxCell>
        <mxCell id="hw-diag-l-div" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#CCCCCC;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="256" y="1050" width="820" height="1" as="geometry"/></mxCell>
        <mxCell id="hw-diag-l-formula" value="E(x) = P · RI · RII · RIII · Λ · R⁻III · R⁻II · R⁻I · P⁻" style="text;strokeColor=none;fillColor=none;fontSize=14;fontStyle=2;fontColor=#1A1A1A;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="264" y="1054" width="804" height="36" as="geometry"/></mxCell>
        <mxCell id="hw-diag-l-legend" value="Where:&#xa;  P = plugboard permutation (Stecker)&#xa;  RI, RII, RIII = selected rotors at current step positions&#xa;  Λ = reflector (UKW-A or UKW-B)&#xa;  R⁻ = inverse rotor permutation (return path)&#xa;  Step advances RI on every keypress; RII/RIII advance on turnover" style="text;strokeColor=none;fillColor=none;fontSize=10;fontColor=#333333;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="264" y="1094" width="804" height="100" as="geometry"/></mxCell>
        <mxCell id="hw-diag-r-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1A4030;" vertex="1" parent="1"><mxGeometry x="1084" y="1022" width="820" height="180" as="geometry"/></mxCell>
        <mxCell id="hw-diag-r-title" value="Total Key Space Calculation" style="text;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#1A2A1A;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1092" y="1026" width="804" height="22" as="geometry"/></mxCell>
        <mxCell id="hw-diag-r-div" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#CCCCCC;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="1084" y="1050" width="820" height="1" as="geometry"/></mxCell>
        <mxCell id="hw-diag-r-formula" value="K = C(5,3) × 3! × 26³ × C(26,2)¹⁰  ≈  1.07 × 10²³" style="text;strokeColor=none;fillColor=none;fontSize=14;fontStyle=2;fontColor=#1A1A1A;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1092" y="1054" width="804" height="36" as="geometry"/></mxCell>
        <mxCell id="hw-diag-r-legend" value="Where:&#xa;  C(5,3) = 10 rotor selections from set of 5&#xa;  3! = 6 rotor orderings&#xa;  26³ = 17,576 ring/start position combinations&#xa;  C(26,2)¹⁰ = 150,738,274,937,250 plugboard settings&#xa;  Combined: ≈10·6·17,576·150.7×10¹² ≈ 1.07×10²³ unique keys" style="text;strokeColor=none;fillColor=none;fontSize=10;fontColor=#333333;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="1092" y="1094" width="804" height="100" as="geometry"/></mxCell>
        <mxCell id="hw-fade-0" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#002B22;strokeColor=none;opacity=15;" vertex="1" parent="1"><mxGeometry x="256" y="950" width="1656" height="20" as="geometry"/></mxCell>
        <mxCell id="hw-fade-1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#002B22;strokeColor=none;opacity=35;" vertex="1" parent="1"><mxGeometry x="256" y="970" width="1656" height="20" as="geometry"/></mxCell>
        <mxCell id="hw-fade-2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#002B22;strokeColor=none;opacity=60;" vertex="1" parent="1"><mxGeometry x="256" y="990" width="1656" height="22" as="geometry"/></mxCell>
        <mxCell id="hw-fade-3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#002B22;strokeColor=none;opacity=88;" vertex="1" parent="1"><mxGeometry x="256" y="1012" width="1656" height="28" as="geometry"/></mxCell>
