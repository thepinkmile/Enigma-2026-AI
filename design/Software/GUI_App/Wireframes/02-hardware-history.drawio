        <mxCell id="hw-img-label" value="[ PERIOD PHOTOGRAPH / ARCHIVE ILLUSTRATION ]" style="text;strokeColor=none;fillColor=none;fontSize=13;fontColor=#3D6B60;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="256" y="186" width="1648" height="210" as="geometry"/></mxCell>
        <mxCell id="hw-img-caption" value="Enigma I three-rotor machine — standard Wehrmacht / Luftwaffe issue, c. 1940" style="text;strokeColor=none;fillColor=none;fontSize=10;fontStyle=2;fontColor=#2A5040;align=center;verticalAlign=bottom;" vertex="1" parent="1"><mxGeometry x="256" y="186" width="1648" height="206" as="geometry"/></mxCell>
        <mxCell id="hw-div1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1A4030;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="256" y="404" width="1656" height="1" as="geometry"/></mxCell>
        <mxCell id="hw-desc-hdr" value="DESCRIPTION" style="text;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#80CBC4;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="256" y="410" width="200" height="24" as="geometry"/></mxCell>
        <mxCell id="hw-desc-p1" value="The Enigma I, also known as the Wehrmacht Enigma or Service Enigma, was the primary cipher machine adopted by the German Army (Heer) and Air Force (Luftwaffe) in 1930. It evolved directly from the commercial Enigma D variant, adding a plugboard (Steckerbrett) that dramatically multiplied the number of possible key settings. The machine used three interchangeable rotors selected from a set of five (I–V), a reflector (UKW-A or UKW-B), and up to ten plugboard pairs, yielding approximately 1.07 × 10²³ possible starting configurations per message." style="text;strokeColor=none;fillColor=none;fontSize=11;fontColor=#AAAAAA;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="256" y="438" width="1648" height="90" as="geometry"/></mxCell>
        <mxCell id="hw-desc-p2" value="Bletchley Park codebreakers, led by Alan Turing and Gordon Welchman, successfully attacked the Enigma I traffic from 1940 onward using electromechanical Bombe machines. The fundamental weakness exploited was the machine’s inability to encrypt a letter as itself — a consequence of the reflector design — combined with predictable message procedures (stereotyped cribs) used by German operators. Despite multiple procedural improvements throughout the war, the basic Enigma I architecture was never fundamentally redesigned, leaving this structural vulnerability intact until the war’s end." style="text;strokeColor=none;fillColor=none;fontSize=11;fontColor=#AAAAAA;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="256" y="534" width="1648" height="84" as="geometry"/></mxCell>
        <mxCell id="hw-div2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1A4030;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="256" y="626" width="1656" height="1" as="geometry"/></mxCell>
        <mxCell id="hw-ref-hdr" value="REFERENCES &amp; FURTHER READING" style="text;strokeColor=none;fillColor=none;fontSize=11;fontStyle=1;fontColor=#80CBC4;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="256" y="632" width="400" height="24" as="geometry"/></mxCell>
        <mxCell id="hw-ref-0" value="•  Cryptomuseum.com — Enigma I (Wehrmacht / Luftwaffe Service Machine)" style="text;strokeColor=none;fillColor=none;fontSize=11;fontColor=#5599DD;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="256" y="660" width="1648" height="20" as="geometry"/></mxCell>
        <mxCell id="hw-ref-1" value="•  Wikipedia: Enigma machine — Wehrmacht variants and key settings" style="text;strokeColor=none;fillColor=none;fontSize=11;fontColor=#5599DD;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="256" y="682" width="1648" height="20" as="geometry"/></mxCell>
