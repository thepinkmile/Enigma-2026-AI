        <mxCell id="c00158" value="SIGNAL ENCODING EXAMPLE  (key 'A' pressed)" style="text;strokeColor=none;fillColor=none;html=0;fontColor=#80CBC4;fontSize=9;fontStyle=1;align=left;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="256" y="739" width="812" height="18" as="geometry"/></mxCell>
        <mxCell id="c00159" value="Plaintext: A&#xa;→ PB:  A → D&#xa;→ R-I:  D → M&#xa;→ R-II:  M → F&#xa;→ R-III:  F → X&#xa;→ UKW-B:  X → T  (reflect)&#xa;→ R-III⁻¹:  T → R&#xa;→ R-II⁻¹:  R → G&#xa;→ R-I⁻¹:  G → P&#xa;→ PB return:  P → W&#xa;➤ Lamp W lights" style="text;strokeColor=none;fillColor=none;html=0;fontColor=#005D4F;fontSize=9;fontStyle=0;align=left;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="256" y="761" width="812" height="263" as="geometry"/></mxCell>
        <mxCell id="c00160" value="" style="rounded=0;whiteSpace=wrap;html=0;fillColor=#001208;strokeColor=#003D33;fontColor=#FFF;fontSize=11;fontStyle=0;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1084" y="731" width="828" height="301" as="geometry"/></mxCell>
        <mxCell id="c00161" value="KEY SPACE CALCULATION" style="text;strokeColor=none;fillColor=none;html=0;fontColor=#80CBC4;fontSize=9;fontStyle=1;align=left;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1092" y="739" width="812" height="18" as="geometry"/></mxCell>
        <mxCell id="c00162" value="K = C(26,10) × 10! × C(5,3) × 3! × 26³&#xa;&#xa;= 150,738,274,937,250  (plugboard)&#xa;× 60  (rotor selection)&#xa;× 17,576  (26³ start positions)&#xa;&#xa;≈ 1.59 × 10²³  configurations&#xa;&#xa;Each ring setting multiplies by 26³.&#xa;Double-step anomaly further increases&#xa;effective key space." style="text;strokeColor=none;fillColor=none;html=0;fontColor=#005D4F;fontSize=9;fontStyle=0;align=left;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1092" y="761" width="812" height="263" as="geometry"/></mxCell>
